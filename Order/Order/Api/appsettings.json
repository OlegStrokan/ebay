{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "GrpcServices": {
    "ProductUrl": "http://product-service:8080",
    "InventoryUrl": "http://inventory-service:8080",
    "PaymentUrl": "http://payment-service:8080",
    "AccountingUrl": "http://accounting-service:8080",
    "UserUrl": "http://user-service:8080"
  },
  "WriteRouting": {
    "Enabled": false,
    "CurrentRegion": "local",
    "Regions": [
      "eu-west-1",
      "us-east-1",
      "ap-southeast-1"
    ]
  },
  "Shipping": {
    "WebhookCallUrl": "http://gateway-api/api/v1/webhooks/shipping/returns/delivered",
    "Dpd": {
      "BaseUrl": "http://localhost:8091/",
      "ApiKey": "dpd_sandbox_key",
      "TimeoutSeconds": 20
    },
    "Ppl": {
      "BaseUrl": "http://localhost:8092/",
      "ApiKey": "ppl_sandbox_key",
      "TimeoutSeconds": 20,
      "MaxPolls": 10,
      "PollIntervalMs": 500
    }
  },
  "IncidentReporter": {
    "Telegram": {
      "Enabled": false,
      "BotToken": "",
      "ChatId": "",
      "TimeoutSeconds": 10
    }
  },
  "Kafka": {
    "BootstrapServers": "localhost:9092",
    "ConsumerGroupId": "order-service",
    "SagaTopic": "order.events",
    "OrderEventsTopic": "order.events",
    "EmailEventsTopic": "email.events",
    "ReturnEventsTopic": "return.events",
    "EnableAutoCommit": false
  },
  "PplBookingReconciliation": {
    "BatchSize": 10,
    "MaxAttempts": 48,
    "PollIntervalSeconds": 1800,
    "RetryIntervalSeconds": 1800
  },
  "CompensationRetry": {
    "BatchSize": 10,
    "MaxRetries": 5,
    "PollIntervalSeconds": 60,
    "BaseRetryDelaySeconds": 60,
    "MaxRetryDelaySeconds": 3600
  },
  "AllowedHosts": "*"
}
